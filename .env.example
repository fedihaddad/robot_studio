# ROS2 Bridge Configuration
VITE_ROS_BRIDGE_URL=ws://192.168.1.100:9090

# Raspberry Pi Configuration
VITE_RASPBERRY_PI_HOST=192.168.1.100
VITE_RASPBERRY_PI_PORT=8080

# Camera Configuration
VITE_CAMERA_STREAM_URL=http://192.168.1.100:8080/?action=stream
VITE_CAMERA_ENABLED=true

# ROS Topics Configuration
VITE_SERVO_COMMAND_TOPIC=/cmd_servo
VITE_SERVO_STATE_TOPIC=/joint_states
VITE_EMERGENCY_STOP_TOPIC=/emergency_stop
# Optional: std_msgs/Bool topic (true = stopped) to mirror E-stop on the dashboard
# VITE_EMERGENCY_STOP_STATE_TOPIC=/emergency_stop_state
VITE_ROBOT_STATE_TOPIC=/robot_state

# Message Types
VITE_SERVO_COMMAND_MSG_TYPE=std_msgs/Float64MultiArray
VITE_SERVO_STATE_MSG_TYPE=sensor_msgs/JointState
VITE_ROBOT_STATE_MSG_TYPE=std_msgs/String

# Servo Configuration
VITE_HEAD_SERVO_COUNT=15
VITE_ARM_SERVO_COUNT=10
VITE_SERVO_MIN_ANGLE=0
VITE_SERVO_MAX_ANGLE=180

